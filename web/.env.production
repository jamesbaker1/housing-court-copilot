# Production BUILD-TIME env, loaded by `next build` (via `npm run deploy`).
#
# ONLY public, client-exposed values belong here. NEXT_PUBLIC_* variables are
# baked into the browser bundle by Next.js convention, so they are PUBLIC, not
# secrets — safe to commit. Real secrets (ANTHROPIC_API_KEY, TURNSTILE_SECRET_KEY,
# CASE_PII_KEY, CF_ACCESS_*) are set server-side with `wrangler secret put` and
# must NEVER appear in this file.

# Cloudflare Turnstile PUBLIC site key for the widget fronting the public LLM
# entry points. Bound to housing-court-copilot.james-baker1628.workers.dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADs6iWW1sqEZD9_q
