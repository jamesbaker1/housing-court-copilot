{
  // Dedicated typecheck for the Ops-owned Cloudflare Worker ENTRY
  // (worker-entry.ts). It is intentionally excluded from the Next.js
  // build tsconfig because it imports the gitignored build artifact
  // `./.open-next/worker.js`, which Next's own type-checker resolves
  // as a real relative path and fails on when the artifact is absent
  // (fresh checkout / after `rm -rf .open-next`). The ambient module
  // declaration in worker-entry.d.ts lets plain `tsc` typecheck it
  // deterministically whether or not `.open-next/` exists, so it stays
  // covered by `npm run typecheck` via this config.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "plugins": []
  },
  "files": ["worker-entry.ts", "worker-entry.d.ts"],
  "include": [],
  "exclude": ["node_modules", ".open-next", ".wrangler"]
}
