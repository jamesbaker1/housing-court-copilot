# Housing Court Copilot — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.

# Anthropic API key — read by the official SDK via `new Anthropic()`.
# Used for vision intake, faithful transcription, defense-spotting,
# the conversational copilot, and the cheap advice-detection classifier.
ANTHROPIC_API_KEY=

# --- Reminders (opt-in SMS court-date reminders, consent-logged) ---
# Opt-in SMS court-date reminders. Each send requires a tenant consent record
# (scope=sms_reminders) and respects contact.safe_to_text. With ANY of these
# absent the reminders pipeline runs in DRY-RUN (schedules + logs, never sends).
# Live sending also requires an approved A2P 10DLC brand/campaign.
# Names match lib/sms/twilio.ts: ACCOUNT_SID, AUTH_TOKEN, FROM (E.164 sender or
# messaging-service-backed from).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Open data (Landlord & Building Intelligence) ---
# Optional Socrata app token for HPD violation/complaint/registration lookups.
# Omitting it still works at low volume (anonymous rate limit). NYC GeoSearch
# (address→BBL) and JustFix Who Owns What are keyless — no env needed.
SOCRATA_APP_TOKEN=

# --- Persistence (dual-mode Case store) ---
# In production on Cloudflare Workers the store uses Cloudflare D1 via the `DB`
# BINDING (configured in wrangler.toml, NOT an env var — do not set it here).
# With no D1 binding present (plain node / local tooling / tests) the store
# falls back to a file-based backend. This optional var overrides where those
# files live; defaults to <cwd>/.data/cases.
HCC_DATA_DIR=

# --- Cloudflare Access (provider gating — used by the Auth phase) ---
# Cloudflare Access protects /provider. middleware verifies the Access JWT
# (Cf-Access-Jwt-Assertion) against your team's public keys. These are env vars
# (set as Worker [vars] / secrets at deploy time), NOT bindings.
#   CF_ACCESS_TEAM_DOMAIN — Access team domain, e.g. myteam.cloudflareaccess.com
#   CF_ACCESS_AUD         — the Application Audience (AUD) tag of the Access app
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
